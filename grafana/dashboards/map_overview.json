      "targets": [
        {
          "dataset": "postgres",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PCC52D03280B7034C"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "WITH constants AS (\r\n    SELECT\r\n        6378137.0        AS a,\r\n        6356752.3142     AS b,\r\n        0.00669437999014 AS e2,\r\n        0.00673949674228 AS ep2\r\n),\r\ninput AS (\r\nSELECT m.sitename AS sitename,\r\n  m.x AS X, m.y AS Y, m.z AS Z\r\nFROM site_metadata m\r\n),\r\np_theta AS (\r\n    SELECT\r\n        sitename, X, Y, Z, a, b, e2, ep2,\r\n        sqrt(X*X + Y*Y)                    AS p,\r\n        atan2(Z * a, sqrt(X*X + Y*Y) * b)  AS theta\r\n    FROM input CROSS JOIN constants\r\n),\r\ncalc AS (\r\n    SELECT\r\n    sitename,\r\n        degrees(atan2(Y, X))  AS lon_deg,\r\n        atan2(\r\n            Z   + ep2 * b * pow(sin(theta), 3),\r\n            p   - e2  * a * pow(cos(theta), 3)\r\n        )                     AS lat_rad\r\n    FROM p_theta\r\n),\r\ncolour AS (\r\n     SELECT\r\n     calc.sitename,\r\n     CAST(count(time_of_data) AS float) / ($__to - $__from) * 86400000 * 100 as colour\r\n     FROM position pos\r\n     RIGHT OUTER JOIN calc ON pos.sitename = calc.sitename\r\n     WHERE $__timeFilter(time_of_data) OR time_of_data IS NULL\r\n     GROUP BY calc.sitename\r\n)\r\nSELECT\r\n    calc.sitename,\r\n    round(degrees(lat_rad)::numeric, 8) AS lat,\r\n    round(lon_deg::numeric,          8) AS lon,\r\n    colour\r\nFROM calc\r\nINNER JOIN colour on calc.sitename = colour.sitename",
          "refId": "B",
          "sql": {
