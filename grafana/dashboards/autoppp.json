      "pluginVersion": "12.3.3",
      "targets": [
        {
          "dataset": "postgres",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  coord                         AS \"Coordinate\",\r\n  avg_diff                      As \"Mean difference from reference\",\r\n  avg_val                       AS \"Mean\",\r\n  std_val                       AS \"Standard deviation\"\r\nFROM (\r\n  SELECT 'x' AS coord,\r\n    AVG(p.x)                        AS avg_val,\r\n    AVG(p.x - m.x)                  AS avg_diff,\r\n    STDDEV(p.x)                     AS std_val\r\n  FROM position p\r\n  LEFT OUTER JOIN site_metadata m ON p.sitename = m.sitename\r\n  WHERE p.sitename = '$station' AND $__timeFilter(time_of_data) \r\n\r\n  UNION ALL\r\n\r\n  SELECT 'y',\r\n    AVG(p.y),\r\n    AVG(p.y- m.y),\r\n    STDDEV(p.y)\r\n  FROM position p\r\n  LEFT OUTER JOIN site_metadata m ON p.sitename = m.sitename\r\n  WHERE p.sitename = '$station' AND $__timeFilter(time_of_data) \r\n\r\n  UNION ALL\r\n\r\n  SELECT 'z',\r\n    AVG(p.z),\r\n    AVG(p.z- m.z),\r\n    STDDEV(p.z)\r\n  FROM position p\r\n  LEFT OUTER JOIN site_metadata m ON p.sitename = m.sitename\r\n  WHERE p.sitename = '$station' AND $__timeFilter(time_of_data) \r\n) stats\r\nORDER BY coord ASC;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
